{
  "name": "@tavern/runtime",
  "private": true,
  "description": "Tavern Runtime.",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun run --filter @zknicker/tavern-openclaw-messenger build && bun build src/index.ts --target bun --format esm --outdir dist",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "ultracite check src",
    "lint:fix": "ultracite fix src",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest"
  },
  "dependencies": {
    "@tavern/agent-runtime-protocol": "workspace:*",
    "@tavern/openclaw-gateway-adapter": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}
