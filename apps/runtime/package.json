{
  "name": "@tavern/runtime",
  "private": true,
  "description": "Tavern Runtime.",
  "version": "1.1.11",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun run --filter @zknicker/tavern-openclaw-messenger build && bun run --filter @zknicker/tavern-openclaw-cortex build && bun run --filter @zknicker/tavern-openclaw-workspace build && bun build src/index.ts --target bun --format esm --outdir dist --external @lancedb/lancedb",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "ultracite check src",
    "lint:fix": "ultracite fix src",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest"
  },
  "dependencies": {
    "@lancedb/lancedb": "0.29.0",
    "@tavern/api": "workspace:*",
    "@tavern/codex-usage": "workspace:*",
    "@tavern/openclaw-gateway-adapter": "workspace:*",
    "bunqueue": "2.6.38",
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/node": "22.19.17",
    "@types/ws": "8.18.1",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "bun": ">=1.3.5"
  }
}
