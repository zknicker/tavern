{
  "default": {
    "identifier": "default",
    "description": "Default Tavern desktop capability set.",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "core:window:allow-start-dragging",
      "core:window:allow-set-theme",
      "process:default",
      "shell:default",
      "updater:default",
      {
        "identifier": "shell:allow-spawn",
        "allow": [
          { "args": true, "name": "binaries/tavern-server", "sidecar": true }
        ]
      }
    ]
  }
}
