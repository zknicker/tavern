{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default Tavern desktop capability set.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-theme",
    "process:default",
    "shell:default",
    "updater:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/tavern-server",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
