{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tavern",
  "version": "1.1.10",
  "identifier": "build.tavern.desktop",
  "build": {
    "beforeBuildCommand": "cd ../.. && bun run --filter @tavern/website build",
    "beforeDevCommand": "cd ../.. && bun run dev",
    "devUrl": "http://localhost:3100",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/tavern-server"],
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "resources": {
      "generated-icons/Assets.car": "Assets.car",
      "icons/AppIcon.icns": "AppIcon.icns"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
