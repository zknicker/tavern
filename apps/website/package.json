{
  "name": "@tavern/website",
  "private": true,
  "version": "1.1.7",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:desktop:icons": "node ../../scripts/build-macos-app-icon.mjs",
    "build:desktop:sidecar": "node ../../scripts/build-tauri-sidecar.mjs",
    "desktop:build": "bun run build:desktop:icons && bun run build:desktop:sidecar && node ../../scripts/run-tauri.mjs build",
    "desktop:build:unsigned": "bun run build:desktop:icons && bun run build:desktop:sidecar && node ../../scripts/release/build-desktop-unsigned.mjs",
    "desktop:build:app": "bun run build:desktop:icons && bun run build:desktop:sidecar && node ../../scripts/run-tauri.mjs build --bundles app",
    "desktop:build:release": "bun run build:desktop:icons && bun run build:desktop:sidecar && node ../../scripts/release/build-desktop-release.mjs",
    "desktop:publish": "bun run desktop:build:release && node ../../scripts/release/create-tauri-latest-json.mjs && node ../../scripts/release/publish-desktop.mjs",
    "desktop:release": "bun run desktop:build:app && node ../../scripts/install-tavern-app.mjs",
    "desktop:dev": "node ../../scripts/run-desktop-dev.mjs",
    "start": "vite preview --strictPort --port 3100",
    "lint": "ultracite check src e2e",
    "lint:fix": "ultracite fix src e2e",
    "test:e2e": "bun e2e/run-playwright.ts",
    "test:e2e:debug": "bun e2e/run-playwright.ts --debug",
    "test:e2e:headed": "bun e2e/run-playwright.ts --headed",
    "test:e2e:live-openclaw": "bun e2e/run-playwright-live-openclaw.ts",
    "test:e2e:screenshot": "bun e2e/run-playwright.ts --screenshot on",
    "test:e2e:screenshot-failures": "bun e2e/run-playwright.ts --screenshot only-on-failure",
    "test:e2e:ui": "bun e2e/run-playwright.ts --ui",
    "tauri": "node ../../scripts/run-tauri.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@hugeicons-pro/core-duotone-rounded": "4.1.0",
    "@hugeicons-pro/core-solid-rounded": "4.1.0",
    "@hugeicons-pro/core-stroke-rounded": "4.1.0",
    "@hugeicons/core-free-icons": "4.0.0",
    "@hugeicons/react": "1.1.6",
    "@react-sigma/core": "5.0.6",
    "@react-three/fiber": "9.6.0",
    "@react-three/postprocessing": "3.0.4",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-form": "1.29.0",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.23",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@tavern/agent-avatars": "workspace:*",
    "@tavern/sdk": "workspace:*",
    "@trpc/client": "11.12.0",
    "@trpc/react-query": "11.12.0",
    "@trpc/server": "11.12.0",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "graphology": "0.26.0",
    "graphology-layout-forceatlas2": "0.10.1",
    "postprocessing": "6.39.1",
    "prismjs": "1.30.0",
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.5.0",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.7",
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hotkeys-hook": "5.2.4",
    "react-router-dom": "7.13.1",
    "react-simple-code-editor": "0.14.1",
    "recharts": "2.15.4",
    "sigma": "3.0.2",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "three": "0.180.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.180.0",
    "@vitejs/plugin-react": "5.2.0",
    "bun-types": "1.3.13",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "vite": "7.3.3"
  }
}
