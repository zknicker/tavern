{
  "name": "@tavern/website",
  "private": true,
  "version": "1.4.18",
  "tavern": {
    "runtime": {
      "minimumVersion": "1.4.18"
    }
  },
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:desktop:icons": "node ../../scripts/build-macos-app-icon.mjs",
    "build:desktop:sidecar": "node ../../scripts/build-electron-sidecar.mjs",
    "desktop:build": "bun run build:desktop:icons && bun run build:desktop:sidecar && bun run build && bun x electron-builder --config electron-builder.config.cjs --mac",
    "desktop:build:unsigned": "bun run build:desktop:icons && bun run build:desktop:sidecar && bun run build && node ../../scripts/release/build-desktop-unsigned.mjs",
    "desktop:build:app": "bun run build:desktop:icons && bun run build:desktop:sidecar && bun run build && bun x electron-builder --config electron-builder.config.cjs --mac dir",
    "desktop:build:release": "bun run build:desktop:icons && bun run build:desktop:sidecar && bun run build && node ../../scripts/release/build-desktop-release.mjs",
    "desktop:publish": "bun run desktop:build:release && node ../../scripts/release/publish-desktop.mjs",
    "desktop:release": "bun run desktop:build:app && node ../../scripts/install-tavern-app.mjs",
    "desktop:dev": "node ../../scripts/run-dev-stack.mjs desktop-runtime",
    "desktop:dev:no-runtime": "node ../../scripts/run-dev-stack.mjs desktop",
    "desktop:dev:launch": "node ../../scripts/run-desktop-dev.mjs",
    "start": "vite preview --strictPort --port 3100",
    "lint": "ultracite check src e2e",
    "lint:fix": "ultracite fix src e2e",
    "test:e2e": "bun e2e/run-playwright.ts",
    "test:e2e:debug": "bun e2e/run-playwright.ts --debug",
    "test:e2e:headed": "bun e2e/run-playwright.ts --headed",
    "test:e2e:screenshot": "bun e2e/run-playwright.ts --screenshot on",
    "test:e2e:screenshot-failures": "bun e2e/run-playwright.ts --screenshot only-on-failure",
    "test:e2e:ui": "bun e2e/run-playwright.ts --ui",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@hugeicons-pro/core-duotone-rounded": "4.1.3",
    "@hugeicons-pro/core-solid-rounded": "4.1.3",
    "@hugeicons-pro/core-stroke-rounded": "4.1.3",
    "@hugeicons/core-free-icons": "4.0.0",
    "@hugeicons/react": "1.1.6",
    "@react-sigma/core": "5.0.6",
    "@react-three/fiber": "9.6.0",
    "@react-three/postprocessing": "3.0.4",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-form": "1.29.0",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.14.2",
    "@tavern/sdk": "workspace:*",
    "@trpc/client": "11.12.0",
    "@trpc/react-query": "11.12.0",
    "@trpc/server": "11.12.0",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "graphology": "0.26.0",
    "graphology-layout-forceatlas2": "0.10.1",
    "postprocessing": "6.39.1",
    "prismjs": "1.30.0",
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.5.0",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.7",
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hotkeys-hook": "5.2.4",
    "react-router-dom": "7.13.1",
    "react-simple-code-editor": "0.14.1",
    "recharts": "3.8.1",
    "sigma": "3.0.2",
    "slot-text": "0.2.2",
    "tailwind-merge": "3.5.0",
    "electron-updater": "6.8.3",
    "tailwindcss": "4.2.1",
    "three": "0.180.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.180.0",
    "@vitejs/plugin-react": "5.2.0",
    "bun-types": "1.3.13",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "vite": "7.3.5"
  }
}
