{
  "name": "@tavern/api",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/runtime/config.ts",
    "./development-chat-demos": "./src/development-chat-demos.ts",
    "./widgets/calendar": "./src/widgets/calendar/contracts.ts",
    "./widgets": "./src/widgets/contracts.ts",
    "./widgets/charts": "./src/widgets/charts/contracts.ts",
    "./openapi.yaml": "./openapi.yaml"
  },
  "scripts": {
    "build": "bun run generate",
    "check": "bun run generate:check && bun test",
    "generate": "openapi-typescript openapi.yaml -o src/generated/openapi.d.ts",
    "generate:check": "openapi-typescript openapi.yaml | diff -u src/generated/openapi.d.ts -",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "1.3.13",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "yaml": "2.9.0"
  },
  "dependencies": {
    "zod": "4.1.11"
  }
}
