{
  "name": "@tavern/api",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/runtime/config.ts",
    "./openapi.yaml": "./openapi.yaml"
  },
  "scripts": {
    "build": "bun run generate",
    "check": "bun run generate:check && bun test",
    "generate": "openapi-typescript openapi.yaml -o src/generated/openapi.d.ts",
    "generate:check": "openapi-typescript openapi.yaml | diff -u src/generated/openapi.d.ts -",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "^1.3.5",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.9.2",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "zod": "4.1.11"
  }
}
