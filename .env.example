SERVER_PORT=8080
APP_ORIGIN=http://localhost:3100
DATABASE_PATH=~/.tavern/tavern.sqlite
ASSISTANT_NAME=Tavern
ASSISTANT_HAS_OWN_NUMBER=false
TAVERN_RUNTIME_HOST=127.0.0.1
TAVERN_RUNTIME_PORT=18790
# Optional override. Defaults to ~/.tavern/runtime.
TAVERN_RUNTIME_ROOT=~/.tavern/runtime
# Optional override. Defaults to $TAVERN_RUNTIME_ROOT/cortex/vector-index.
# TAVERN_CORTEX_VECTOR_PATH=~/.tavern/runtime/cortex/vector-index
TAVERN_RUNTIME_NAME=Tavern Runtime
# Optional override. Defaults to the packaged runtime version.
# TAVERN_RUNTIME_VERSION=1.1.0
# Tavern Runtime always manages the pinned npm OpenClaw install and launches it with Seatbelt.
# TAVERN_OPENCLAW_VERSION=2026.5.12-beta.4
# TAVERN_OPENCLAW_GATEWAY_PORT=18789
# Optional override for an already-managed Tavern Messenger plugin copy.
# TAVERN_OPENCLAW_PLUGIN_PATH=/path/to/tavern-openclaw-messenger
# Optional deploy target for Runtime's managed Tavern Messenger plugin copy.
# TAVERN_OPENCLAW_PLUGIN_DEPLOY_PATH=~/.tavern/openclaw-plugins/tavern-openclaw-messenger
HUGEICONS_LICENSE_KEY=
# Runtime Discord channel support
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
# DISCORD_PUBLIC_KEY=
# Runtime Codex provider support
# OPENAI_API_KEY=
# CODEX_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=
# Runtime OpenCode provider support
# OPENCODE_PROVIDER=anthropic
# OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514
# OPENCODE_SMALL_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_BASE_URL=
# Desktop release publishing
# TAVERN_RELEASE_BASE_URL=https://example.com/mac
# TAVERN_RELEASE_S3_URI=s3://example-bucket/mac
# TAVERN_HOMEBREW_TAP_REPO=zknicker/homebrew-tavern
# TAVERN_HOMEBREW_TAP_DIR=/path/to/homebrew-tavern
# TAURI_UPDATER_PUBLIC_KEY=
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
# APPLE_SIGNING_IDENTITY=
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
# APPLE_API_KEY=
# APPLE_API_ISSUER=
# APPLE_API_KEY_PATH=
