SERVER_PORT=8080
APP_ORIGIN=http://localhost:3100
# Dev stack defaults are generated per worktree under ~/.tavern/dev/<worktree-id>/.
# TAVERN_DEV_STACK_ID=tavern-local
# TAVERN_DEV_PORT_BASE=43000
# DATABASE_PATH=~/.tavern/dev/tavern-local/tavern.sqlite
ASSISTANT_NAME=Tavern
ASSISTANT_HAS_OWN_NUMBER=false
TAVERN_RUNTIME_HOST=127.0.0.1
TAVERN_RUNTIME_PORT=18790
# Optional bearer token for Runtime API auth. Runtime generates one on first start
# at <runtime-root>/runtime-api-token. Override here to use a fixed token.
# TAVERN_RUNTIME_TOKEN=
# Optional override. Dev stack default is ~/.tavern/dev/<worktree-id>/runtime.
# TAVERN_RUNTIME_ROOT=~/.tavern/dev/tavern-local/runtime
# Optional heavy task artifact storage override. Defaults to <runtime-root>/artifacts.
# TAVERN_TASK_ARTIFACTS_DIR=~/.tavern/dev/tavern-local/runtime/artifacts
# Optional override. Defaults to $TAVERN_RUNTIME_ROOT/wiki.
# TAVERN_WIKI_HUB_PATH=~/.tavern/dev/tavern-local/runtime/wiki
TAVERN_RUNTIME_NAME=Tavern Runtime
# Optional override. Defaults to the packaged runtime version.
# TAVERN_RUNTIME_VERSION=1.1.0
# Tavern Runtime runs the local AI SDK agent path. Codex and Claude use
# OAuth-backed AI SDK CLI providers; OpenAI uses OPENAI_API_KEY.
# TAVERN_AGENT_PROVIDER=openai
# TAVERN_AGENT_MODEL=
# TAVERN_AGENT_OPENAI_MODEL=gpt-4.1-mini
# TAVERN_AGENT_CODEX_CLI_COMMAND=codex
# TAVERN_AGENT_CODEX_MODEL=gpt-5.5
# TAVERN_AGENT_CLAUDE_CODE_COMMAND=claude
# TAVERN_AGENT_CLAUDE_MODEL=claude-sonnet-4-6
# Optional Claude Code subscription token for non-interactive Runtime turns.
# Create one with `claude setup-token` when plain `claude -p "hello"` cannot
# use your local Claude.ai login.
# TAVERN_AGENT_CLAUDE_CODE_AUTH_TOKEN=
# TAVERN_AGENT_MODEL_DISCOVERY_TIMEOUT_MS=1500
# TAVERN_AGENT_TURN_TIMEOUT_MS=300000
# TAVERN_TASK_TURN_TIMEOUT_MS=1800000
# TAVERN_AGENT_HOME=~/.tavern/dev/tavern-local/runtime/agent
# TAVERN_AGENT_WORKSPACE=~/.tavern/dev/tavern-local/runtime/agent/workspace
# TAVERN_AGENT_BASE_URL=
# TAVERN_AGENT_API_KEY=
# Optional override for the Wiki recall search engine module path. Defaults
# to the workspace package in dev and the staged Runtime copy when packaged.
# TAVERN_RUNTIME_QMD_PATH=
# OPENAI_API_KEY=
HUGEICONS_LICENSE_KEY=
# MerchBase Plugin
# TAVERN_MERCHBASE_ENABLED=true
# TAVERN_MERCHBASE_API_KEY=
# TAVERN_MERCHBASE_BASE_URL=https://app.merchbase.co
# TAVERN_MERCHBASE_DEFAULT_ACCOUNT=
# TAVERN_MERCHBASE_DEFAULT_MARKETPLACE=
# Google Plugin
# TAVERN_GOOGLE_OAUTH_CLIENT_ID=
# TAVERN_GOOGLE_OAUTH_CLIENT_SECRET=
# Browser Plugin: root for managed Chrome profiles (default ~/.tavern/browser)
# TAVERN_BROWSER_HOME=
# Runtime Discord channel support
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
# DISCORD_PUBLIC_KEY=
# Runtime Codex provider support
# OPENAI_API_KEY=
# CODEX_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=
# Runtime OpenCode provider support
# OPENCODE_PROVIDER=anthropic
# OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514
# OPENCODE_SMALL_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_BASE_URL=
# Desktop release publishing
# TAVERN_RELEASE_BASE_URL=https://example.com/mac
# TAVERN_RELEASE_S3_URI=s3://example-bucket/mac
# TAVERN_HOMEBREW_TAP_REPO=zknicker/homebrew-tavern
# TAVERN_HOMEBREW_TAP_DIR=/path/to/homebrew-tavern
# TAURI_UPDATER_PUBLIC_KEY=
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
# APPLE_SIGNING_IDENTITY=
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
# APPLE_API_KEY=
# APPLE_API_ISSUER=
# APPLE_API_KEY_PATH=
